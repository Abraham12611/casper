{
  "_meta": {
    "version": "1.0.0",
    "source": "UI screenshots — dark theme (support inbox) + light theme (AI notetaker)",
    "purpose": "Cursor AI replication guide — maps every visual effect to its exact element context",
    "themes": ["dark", "light"]
  },

  "DO_NOT_RULES": {
    "gradients": [
      "DO NOT apply status-badge colors (green/orange/blue) to card backgrounds",
      "DO NOT apply chat bubble colors to sidebar backgrounds",
      "DO NOT use light-theme surface colors in dark-theme components",
      "DO NOT apply primary action blue (#2563eb) to body text — only to active nav items and links",
      "DO NOT use timestamp gray (#6b7280) for primary content text",
      "DO NOT apply incoming-bubble dark bg to outgoing-bubble elements — they are inverted",
      "DO NOT use the full-white (#ffffff) card background in the dark theme — use layered darks only",
      "DO NOT place shadows on text elements — only on container/card/panel surfaces"
    ],
    "colors": [
      "DO NOT confuse border color with background color — borders are always 1–2 stops lighter than their container bg",
      "DO NOT use status green (#22c55e) for anything other than resolved/online indicators",
      "DO NOT use status orange (#f97316) for anything other than 'in progress' or 'pending' indicators",
      "DO NOT apply active-sidebar blue background (#dbeafe) to the main content area — sidebar only"
    ],
    "layout": [
      "DO NOT apply panel-level border-radius to inner list items — only to cards and container panels",
      "DO NOT add box-shadows to sidebar list items — shadows belong on floating panels and message bubbles only"
    ]
  },

  "colorTokens": {
