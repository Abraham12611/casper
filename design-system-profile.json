  "components": {

    "layout": {
      "dark": {
        "threeColumnLayout": {
          "description": "navStrip | sidebar | conversationList | chatPanel",
          "columns": {
            "navStrip": {
              "width": "56px",
              "background": "#0d0d13",
              "borderRight": "none",
              "padding": "12px 0"
            },
            "sidebar": {
              "width": "200px",
              "background": "#161621",
              "borderRight": "1px solid #2a2a3c",
              "padding": "12px 0"
            },
            "conversationList": {
              "width": "260px",
              "background": "#1a1a26",
              "borderRight": "1px solid #2a2a3c"
            },
            "chatPanel": {
              "flex": 1,
              "background": "#1e1e2c"
            }
          }
        }
      },
      "light": {
        "twoColumnLayout": {
          "description": "iconStrip | sidebar | contentArea",
          "columns": {
            "iconStrip": {
              "width": "52px",
              "background": "#f9fafb",
              "borderRight": "1px solid #e5e7eb"
            },
            "sidebar": {
              "width": "260px",
              "background": "#f9fafb",
              "borderRight": "1px solid #e5e7eb",
              "padding": "12px 0"
            },
            "contentArea": {
              "flex": 1,
              "background": "#ffffff",
              "padding": "32px 40px"
            }
          }
        }
      }
    },

    "navigationIcons": {
      "dark": {
        "container": {
          "width": "32px",
          "height": "32px",
          "borderRadius": "8px",
          "margin": "4px auto",
          "display": "flex",
          "alignItems": "center",
          "justifyContent": "center"
        },
        "default": {
          "iconColor": "#6b7280",
          "iconSize": "18px",
          "background": "transparent"
        },
        "hover": {
          "background": "#22222e",
          "iconColor": "#9ca3af",
          "transition": "background 150ms ease, color 150ms ease"
        },
        "active": {
          "background": "#26263a",
          "iconColor": "#f0f0f5"
        },
        "notification": {
          "dot": {
            "width": "8px",
            "height": "8px",
            "borderRadius": "50%",
            "background": "#3b82f6",
            "position": "absolute",
            "top": "4px",
            "right": "4px",
            "border": "2px solid #0d0d13"
          }
        }
      },
      "light": {
        "default": {
          "iconColor": "#6b7280",
          "iconSize": "18px",
          "background": "transparent"
        },
        "active": {
          "iconColor": "#2563eb",
          "background": "transparent"
        },
        "hover": {
          "iconColor": "#374151"
        }
      }
    },

    "sidebarNavItem": {
      "dark": {
        "container": {
          "height": "32px",
          "borderRadius": "6px",
          "padding": "0 10px",
