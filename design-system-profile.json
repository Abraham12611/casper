        "navStrip":       "#0d0d13",
        "sidebar":        "#161621",
        "conversationList": "#1a1a26",
        "chatPanel":      "#1e1e2c",
        "inputArea":      "#1a1a26",
        "hoverListItem":  "#22222e",
        "activeListItem": "#26263a"
      },
      "surfaces": {
        "incomingBubble": "#252535",
        "outgoingBubble": "#f0f0f3",
