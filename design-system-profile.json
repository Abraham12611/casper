        "divider":        "#2a2a3c"
      },
      "text": {
        "primary":    "#f0f0f5",
        "secondary":  "#9ca3b4",
        "muted":      "#6b7280",
        "timestamp":  "#52525e",
        "incomingBubbleText":  "#f0f0f5",
