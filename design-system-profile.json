          "border": "2px solid #1a1a26",
          "position": "absolute",
          "bottom": "0",
          "right": "0",
          "states": {
            "open":       { "background": "transparent", "borderColor": "#6b7280" },
            "resolved":   { "background": "#22c55e",     "borderColor": "#1a1a26" },
