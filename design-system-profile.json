          "color": "#f0f0f5"
        },
        "actionIcons": {
          "color": "#6b7280",
          "size": "16px",
          "gap": "8px",
          "marginLeft": "auto"
        },
        "statusBadge": {
          "position": "right",
          "marginLeft": "auto"
        }
      }
    },

    "filterBar": {
      "dark": {
        "container": {
          "padding": "8px 14px",
          "borderBottom": "1px solid #2a2a3c",
          "display": "flex",
          "alignItems": "center",
          "gap": "10px"
        },
        "title": {
          "fontSize": "13px",
          "fontWeight": "500",
          "color": "#f0f0f5"
        },
        "iconButton": {
          "color": "#6b7280",
          "size": "15px",
          "hover": { "color": "#9ca3af" }
        }
      }
    }
  },

  "spacing": {
    "containerPadding": {
      "navStrip":          "8px 0",
      "sidebar":           "8px 0",
      "conversationList":  "0",
      "chatPanel":         "0",
      "contentArea":       "32px 40px"
    },
    "listItemPadding": {
      "sidebarNavItem":         "0 10px",
      "conversationListItem":   "10px 14px",
      "sectionHeader":          "16px 12px 4px"
    },
    "gaps": {
      "avatarToContent":   "10px",
      "iconToLabel":       "8px",
      "itemGap":           "1px",
      "sectionGap":        "8px"
    }
  },

  "borderRadius": {
    "navIcon":         "8px",
    "sidebarItem":     "6px",
    "chatBubble": {
      "incoming":      "4px 16px 16px 16px",
      "outgoing":      "16px 4px 16px 16px"
    },
    "statusBadge":     "4px",
    "statusDot":       "50%",
    "avatar":          "50%",
    "searchBar":       "8px",
    "emailBlock":      "8px",
    "emailHeaderIcon": "6px",
    "panel":           "0",
    "floatingPanel":   "12px"
  },

  "shadows": {
    "dark": {
      "floatingPanel":   "0 8px 24px rgba(0, 0, 0, 0.5)",
      "chatBubble":      "none",
      "dropdown":        "0 4px 16px rgba(0, 0, 0, 0.4)",
      "DO_NOT_APPLY_TO": ["list items", "sidebar items", "text elements", "icons"]
    },
    "light": {
      "floatingPanel":   "0 4px 16px rgba(0, 0, 0, 0.08)",
      "emailBlock":      "0 1px 4px rgba(0, 0, 0, 0.04)",
      "dropdown":        "0 4px 12px rgba(0, 0, 0, 0.1)",
      "DO_NOT_APPLY_TO": ["sidebar list items", "content text", "bullet lists"]
    }
  },

  "transitions": {
    "default":        "all 150ms ease",
    "background":     "background 120ms ease",
    "color":          "color 120ms ease",
    "iconHover":      "color 150ms ease, opacity 150ms ease",
    "DO_NOT_ANIMATE": ["layout shifts", "font-size", "border-radius on hover"]
  },

  "iconography": {
    "sizes": {
      "navStrip":     "18px",
      "sidebarItem":  "14px",
      "listItemMeta": "13px",
      "actionButton": "16px",
      "badge":        "12px"
    },
    "colorContext": {
      "navStrip_inactive":   "inherit from container — #6b7280",
      "navStrip_active":     "#f0f0f5 (dark) / #2563eb (light)",
      "sidebarItem_inactive":"#6b7280 (both themes)",
      "sidebarItem_active":  "#f0f0f5 (dark) / #2563eb (light)",
      "actionIcons":         "#6b7280 (both themes)",
      "statusIcons":         "match status color token exactly"
    }
  },

  "implementationNotes": {
    "darkTheme": [
      "Use a CSS class `.dark` on the root `<html>` or `<body>` element to scope all dark tokens",
      "Background depth increases left-to-right: navStrip (#0d0d13) → sidebar (#161621) → list (#1a1a26) → chat (#1e1e2c)",
      "Never use pure black (#000000) — all backgrounds use very dark blue-gray, not neutral black",
      "Outgoing chat bubbles use near-white (#f0f0f3) with dark text (#1a1a26) — invert of the panel bg",
      "Status dots always have a 2px solid border matching their immediate container background (prevents halo on dark bg)",
      "Font rendering: use `font-smoothing: antialiased` throughout dark theme for crisp text on dark bg"
    ],
    "lightTheme": [
      "Use CSS class `.light` or default (no class) to scope light tokens",
      "The active sidebar item uses a dedicated blue-tinted background (#eff6ff) — not just bold text",
      "Section group labels ('Today', 'Yesterday') are lighter gray (#9ca3af), smaller, and spaced above their items",
      "Main content has generous horizontal padding (40px) — not flush to the panel edge",
      "Email compose block is contained with a border + subtle border-radius — it reads as an embedded card, not a raw form",
      "Bullet dots (#d1d5db) are intentionally muted — they are structural, not decorative"
    ],
    "shared": [
      "Avatar fallbacks use initials with theme-appropriate bg/text contrast",
      "Timestamps are always the most muted color in both themes — they should recede visually",
      "ALL-CAPS labels (section headers, status badges) use letter-spacing: 0.05–0.06em",
      "List item hover states must be subtle — never match the active state color",
      "Dividers use a single `border-bottom` line, never a full `<hr>` with margin on both sides"
    ]
  }
}
